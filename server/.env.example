# Copy to .env and fill in your values

PORT=5002
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/flixcoach

JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRE=30d

# Your deployed frontend URL (for CORS + email links)
CLIENT_URL=https://www.flixcoach.de

NODE_ENV=production

# Groq AI
GROQ_API_KEY=

# Gmail SMTP (use App Password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# VAPID keys (npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRICE_ID=price_...
